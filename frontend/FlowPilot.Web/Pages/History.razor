@page "/history"
@using FlowPilot.Web.Services
@using FlowPilot.Web.Models

@inject ApiService ApiService

<h3>Workflow Run History</h3>

@if (histories.Count == 0)
{
    <p>No executions yet.</p>
}
else
{
    @foreach (var item in histories)
    {
        <div class="card mb-3">

            <div class="card-body">

                <h5>@item.WorkflowName</h5>

                <small>
                    @item.ExecutedAt.ToLocalTime()
                </small>

                <hr />

                <strong>Input</strong>

                <pre>@item.UserInput</pre>

                <strong>Output</strong>

                <pre>@item.Result</pre>

            </div>

        </div>
    }
}

@code {

    private List<RunHistory> histories = new();

    protected override async Task OnInitializedAsync()
    {
        histories = await ApiService.GetHistory();
    }

}