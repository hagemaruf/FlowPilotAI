@page "/workflows/run/{WorkflowId}"

@using FlowPilot.Web.Models
@using FlowPilot.Web.Services

@inject ApiService ApiService

<h3>Run Workflow</h3>

@if (workflow == null)
{
    <p>Loading...</p>
}
else
{
    <div class="card mb-4">

        <div class="card-body">

            <h4>@workflow.Name</h4>

            <p class="text-muted">
                @workflow.Description
            </p>

            @if (workflow.Steps.Any())
            {
                <div class="card mb-4">

                    <div class="card-header">

                        <strong>Workflow Steps</strong>

                    </div>

                    <div class="card-body">

                        @foreach (var step in workflow.Steps.OrderBy(s => s.Order))
                        {
                            <div class="d-flex align-items-start mb-3">

                                <div class="me-3">

                                    <span class="badge bg-primary rounded-pill">
                                        @step.Order
                                    </span>

                                </div>

                                <div>

                                    <strong>
                                        @step.Name
                                    </strong>

                                    <div class="text-muted small">
                                        @step.Prompt
                                    </div>

                                </div>

                            </div>
                        }

                    </div>

                </div>
            }

            <div class="mb-3">

                <label class="form-label">
                    User Input
                </label>

                <textarea class="form-control"
                          rows="8"
                          @bind="UserInput">
                </textarea>

            </div>

            <button class="btn btn-primary"
                    @onclick="RunWorkflow"
                    disabled="@IsRunning">

                @if (IsRunning)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Running...</span>
                }
                else
                {
                    <span>Run Workflow</span>
                }

            </button>

        </div>

    </div>

    @if (ExecutionResult != null)
    {
        <h4>Execution Steps</h4>

        @foreach (var step in ExecutionResult.Steps)
        {
            <div class="card mb-3">

                <div class="card-header bg-primary text-white">

                    @step.Step

                </div>

                <div class="card-body">

                    <pre class="mb-0">@step.Result</pre>

                </div>

            </div>
        }

        <div class="card border-success">

            <div class="card-header bg-success text-white">

                Final Result

            </div>

            <div class="card-body">

                <pre class="mb-0">
@ExecutionResult.FinalResult
                </pre>

            </div>

        </div>
    }
}

@code {

    [Parameter]
    public string WorkflowId { get; set; } = "";

    private Workflow? workflow;

    private string UserInput = "";

    private bool IsRunning;

    private WorkflowExecutionResult? ExecutionResult;

    protected override async Task OnInitializedAsync()
    {
        var workflows =
            await ApiService.GetWorkflows();

        workflow =
            workflows.FirstOrDefault(
                x => x.Id == WorkflowId);
    }

    private async Task RunWorkflow()
    {
        IsRunning = true;

        ExecutionResult =
            await ApiService.RunWorkflow(
                WorkflowId,
                UserInput);

        IsRunning = false;
    }

}